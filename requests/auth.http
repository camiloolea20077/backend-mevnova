# ─────────────────────────────────────────────────────────────
#  SUPER ADMIN
# ─────────────────────────────────────────────────────────────

### Login Super Admin  →  retorna access_token directo
POST http://localhost:{{port}}/api/auth/super-admin/login HTTP/1.1
Content-Type: application/json

{
    "username": "superadmin",
    "password": "securepassword123"
}

###

# ─────────────────────────────────────────────────────────────
#  FLUJO NORMAL: pre-auth → login → select-sede
# ─────────────────────────────────────────────────────────────

### Paso 1 — Pre-Auth (valida empresa por código o NIT)
# Usar solo uno de los dos campos: companyCodigo o companyNit
POST http://localhost:{{port}}/api/auth/pre-auth HTTP/1.1
Content-Type: application/json

{
    "companyCodigo": "HOSP_BOGOTA"
}

###

### Paso 1b — Pre-Auth por NIT
POST http://localhost:{{port}}/api/auth/pre-auth HTTP/1.1
Content-Type: application/json

{
    "companyNit": "900123456"
}

###

### Paso 2 — Login (requiere el X-Pre-Auth-Token del paso anterior)
# Reemplaza <pre_auth_token> con el token recibido en /pre-auth
POST http://localhost:{{port}}/api/auth/login HTTP/1.1
X-Pre-Auth-Token: eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiJwcmVfYXV0aCIsInRpcG9fdG9rZW4iOiJQUkVfQVVUSCIsImVtcHJlc2FfaWQiOjQsImp0aSI6IjZkOTZlOWRhLWQ1ZmUtNDJlMi05MjQwLTg4ZDQwNzhkODg5ZiIsImlhdCI6MTc3NjczMDc5NSwiZXhwIjoxNzc2NzMxMDk1fQ.4xtvWcyHy_w6-_qyJeOogm4xqNUHfg76XTFhsZN-LydcdWR2IRyHas8lA33aNSsuJVXZ7U6WAgsLpEQ4xexj3w

{
    "username": "admin_hospital",
    "password": "Segura123!"
}

###

### Paso 3 — Seleccionar sede (requiere el X-Session-Token del paso anterior)
# Reemplaza <session_token> con el token recibido en /login
POST http://localhost:{{port}}/api/auth/select-sede HTTP/1.1
X-Session-Token: <session_token>
Content-Type: application/json

{
    "sedeId": 1
}

###

# ─────────────────────────────────────────────────────────────
#  OPERACIONES CON SESIÓN ACTIVA
# ─────────────────────────────────────────────────────────────

### Renovar token (refresh)
POST http://localhost:{{port}}/api/auth/refresh HTTP/1.1
Authorization: Bearer {{token}}

###

### Cambiar contraseña
POST http://localhost:{{port}}/api/auth/change-password HTTP/1.1
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "currentPassword": "securepassword123",
    "newPassword": "nuevaPassword456!"
}

###

### Logout
POST http://localhost:{{port}}/api/auth/logout HTTP/1.1
Authorization: Bearer {{token}}

###
