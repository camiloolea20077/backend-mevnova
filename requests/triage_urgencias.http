# ─────────────────────────────────────────────────────────────────────────────

@rx_base = http://localhost:{{port}}/api/prescriptions

### HU-031 — Registrar prescripción
POST {{rx_base}}
Content-Type: application/json
Authorization: {{token}}

{
  "atencionId": 1,
  "observaciones": "Administrar antes de cirugía",
  "items": [
    {
      "servicioSaludId": 4,
      "dosis": 1.0,
      "unidadDosis": "g",
      "viaAdministracionId": 27,
      "frecuenciaDosisId": 24,
      "duracionDias": 3,
      "cantidadDespachar": 3,
      "indicaciones": "Administrar IV lento en 30 minutos"
    }
  ]
}

###

### HU-031 — Listar prescripciones de la atención
GET {{rx_base}}/by-attention/1
Authorization: {{token}}

###

### HU-031 — Anular prescripción
DELETE {{rx_base}}/1
Authorization: {{token}}

###

# ─────────────────────────────────────────────────────────────────────────────
# HU-032  Cierre de atención
# ─────────────────────────────────────────────────────────────────────────────

### HU-032 — Cerrar atención con conducta ALTA
PATCH {{base}}/1/close
Content-Type: application/json
Authorization: {{token}}

{
  "conduct": "ALTA",
  "plan": "Alta con analgésicos orales y control en 48 horas por consulta externa",
  "analysis": "Dolor abdominal resuelto. Apendicitis aguda operada sin complicaciones.",
  "observations": "Paciente tolera vía oral. Afebril. Herida quirúrgica en buen estado."
}

###

### HU-032 — Cerrar atención con conducta REMISION
PATCH {{base}}/1/close
Content-Type: application/json
Authorization: {{token}}

{
  "conduct": "REMISION",
  "plan": "Remisión a Hospital de mayor complejidad para manejo especializado",
  "analysis": "Paciente requiere manejo en UCI de III nivel.",
  "observations": "Ambulancia coordinada. Epicrisis adjunta."
}

###

# ─────────────────────────────────────────────────────────────────────────────
# HU-033  Solicitud de hospitalización
# ─────────────────────────────────────────────────────────────────────────────

### HU-033 — Solicitar hospitalización
PATCH {{base}}/2/hospitalization-request
Content-Type: application/json
Authorization: {{token}}

{
  "targetService": "Cirugía General",
  "justification": "Paciente con apendicitis aguda fase III que requiere intervención quirúrgica urgente y manejo postoperatorio intrahospitalario.",
  "observations": "Cirujano de turno notificado. OR disponible en 30 minutos."
}

