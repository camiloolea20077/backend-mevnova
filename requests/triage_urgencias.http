@port = 9001
@token = Bearer eyJhbGciOiJIUzUxMiJ9..nWgFiuImOtFxaajX3KxMaC1jprRkl-gyj5OafQ7aSaZBtLqzeLQRjRcliJfLj3MCwSwrzD8AyEgJZ0AEpnoUkw

@base = http://localhost:{{port}}/api/attentions

### HU-021 — Consultar atención abierta de una admisión (creada automáticamente)
GET {{base}}/by-admission/3
Authorization: {{token}}

###

### HU-025 — Registrar triage (nivel III — Urgente)
# {id} = ID de la atención (atencion.id) obtenida del GET anterior
PATCH {{base}}/1/triage
Content-Type: application/json
Authorization: {{token}}

{
  "triageLevel": "III",
  "chiefComplaint": "Dolor abdominal agudo en fosa ilíaca derecha con irradiación, acompañado de náuseas y fiebre",
  "systolicPressure": 130,
  "diastolicPressure": 85,
  "heartRate": 98,
  "respiratoryRate": 18,
  "temperature": 38.2,
  "oxygenSaturation": 97,
  "weight": 72.5,
  "height": 1.68,
  "glucometry": null,
  "observations": "Signo de McBurney positivo"
}

###

### HU-025 — Registrar triage (nivel I — Resucitación)
PATCH {{base}}/1/triage
Content-Type: application/json
Authorization: {{token}}

{
  "triageLevel": "I",
  "chiefComplaint": "Paciente en paro cardiorrespiratorio",
  "systolicPressure": 0,
  "diastolicPressure": 0,
  "heartRate": 0,
  "respiratoryRate": 0,
  "temperature": 35.8,
  "oxygenSaturation": 70,
  "weight": 80.0,
  "height": 1.75,
  "glucometry": null,
  "observations": "Se inicia RCP inmediatamente"
}

###

### HU-025 — Registrar triage (nivel V — No urgente)
PATCH {{base}}/2/triage
Content-Type: application/json
Authorization: {{token}}

{
  "triageLevel": "V",
  "chiefComplaint": "Resfriado común de 3 días de evolución, sin complicaciones",
  "systolicPressure": 115,
  "diastolicPressure": 75,
  "heartRate": 72,
  "respiratoryRate": 16,
  "temperature": 37.1,
  "oxygenSaturation": 99,
  "weight": 65.0,
  "height": 1.62,
  "glucometry": null,
  "observations": null
}

###

### HU-026 — Reclasificar triage (empeora de III a II)
PATCH {{base}}/1/triage/reclassify
Content-Type: application/json
Authorization: {{token}}

{
  "newTriageLevel": "II",
  "justification": "Paciente presenta deterioro clínico: hipotensión y taquicardia progresiva, sospecha de sepsis abdominal"
}

###

### HU-026 — Reclasificar triage (mejora de II a IV)
PATCH {{base}}/2/triage/reclassify
Content-Type: application/json
Authorization: {{token}}

{
  "newTriageLevel": "IV",
  "justification": "Paciente estabilizado tras analgesia. Signos vitales normales, dolor controlado"
}

###

### HU-027 — Cola de urgencias de la sede
GET {{base}}/emergency-queue
Authorization: {{token}}

###

# ─────────────────────────────────────────────────────────────────────────────
# HU-028  Consola de atención de urgencias
# ─────────────────────────────────────────────────────────────────────────────

### HU-028 — Cargar consola completa del paciente
# Retorna atencion + signos vitales + notas clínicas + diagnósticos + órdenes + prescripciones
GET {{base}}/1/console
Authorization: {{token}}

###

### HU-028 — Iniciar atención (EN_SALA_ESPERA → EN_ATENCION)
PATCH {{base}}/2/start
Authorization: {{token}}

###

### HU-028 — Actualizar notas clínicas (parcial, solo los campos enviados)
PATCH {{base}}/1/notes
Content-Type: application/json
Authorization: {{token}}

{
  "chiefComplaint": "Dolor abdominal agudo en fosa ilíaca derecha con irradiación",
  "currentIllness": "Cuadro de 24 horas de evolución. Inicia con dolor periumbilical que migra a FID. Náuseas, vómito en dos ocasiones. Fiebre 38.2°C.",
  "medicalHistory": "Sin antecedentes quirúrgicos. HTA controlada. Sin alergias conocidas.",
  "physicalExam": "Abdomen tenso. McBurney (+). Rovsing (+). Defensa muscular voluntaria. Peristaltismo disminuido.",
  "analysis": "Cuadro compatible con apendicitis aguda fase II. Hemograma con leucocitosis 14.500. PCR elevada.",
  "plan": "Interconsulta a cirugía urgente. Dieta absoluta. Hidratación IV. Analgesia.",
  "observations": "Familia informada sobre posible intervención quirúrgica"
}

###

# ─────────────────────────────────────────────────────────────────────────────
# HU-029  Diagnósticos
# ─────────────────────────────────────────────────────────────────────────────

@diag_base = http://localhost:{{port}}/api/diagnoses

### HU-029 — Buscar en catálogo CIE-10
GET {{diag_base}}/catalog/search?q=apendicitis
Authorization: {{token}}

###

### HU-029 — Registrar diagnóstico PRINCIPAL
POST {{diag_base}}
Content-Type: application/json
Authorization: {{token}}

{
  "atencionId": 3,
  "catalogoDiagnosticoId": 183,
  "tipoDiagnostico": "PRINCIPAL",
  "esConfirmado": true,
  "observaciones": "Apendicitis aguda confirmada por clínica e imagen"
}

###

### HU-029 — Registrar diagnóstico RELACIONADO
POST {{diag_base}}
Content-Type: application/json
Authorization: {{token}}

{
  "atencionId": 1,
  "catalogoDiagnosticoId": 179,
  "tipoDiagnostico": "RELACIONADO",
  "esConfirmado": false,
  "observaciones": null
}

###

### HU-029 — Listar diagnósticos de la atención
GET {{diag_base}}/by-attention/1
Authorization: {{token}}

###

### HU-029 — Eliminar diagnóstico (anular)
DELETE {{diag_base}}/1
Authorization: {{token}}

###

# ─────────────────────────────────────────────────────────────────────────────
# HU-030  Órdenes clínicas
# ─────────────────────────────────────────────────────────────────────────────

@orden_base = http://localhost:{{port}}/api/clinical-orders

### HU-030 — Registrar orden clínica (laboratorio)
POST {{orden_base}}
Content-Type: application/json
Authorization: {{token}}

{
  "atencionId": 3,
  "tipoOrden": "LABORATORIO",
  "observaciones": "Procesamiento urgente",
  "items": [
    {
      "servicioSaludId": 4,
      "cantidad": 1,
      "indicaciones": "Cuadro febril con sospecha de proceso infeccioso",
      "urgencia": "URGENTE"
    },
    {
      "servicioSaludId": 3,
      "cantidad": 1,
      "indicaciones": "Valorar función renal preoperatoria",
      "urgencia": "PRIORITARIA"
    }
  ]
}

###

### HU-030 — Listar órdenes de la atención
GET {{orden_base}}/by-attention/1
Authorization: {{token}}

###

### HU-030 — Anular orden clínica
DELETE {{orden_base}}/1
Authorization: {{token}}

###

# ─────────────────────────────────────────────────────────────────────────────
