@port = 9001
@token = Bearer eyJhbGciOiJIUzUxMiJ9..nWgFiuImOtFxaajX3KxMaC1jprRkl-gyj5OafQ7aSaZBtLqzeLQRjRcliJfLj3MCwSwrzD8AyEgJZ0AEpnoUkw
@base = http://localhost:{{port}}/api/health-professionals

### Crear profesional de salud
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "thirdPartyId": 12,
  "medicalRegistrationNumber": "RM-12345",
  "primarySpecialtyId": 51,
  "startDate": "2024-01-15",
  "observations": "Médico general con experiencia en urgencias"
}

###

### Crear profesional sin registro médico (ej. enfermero)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "thirdPartyId": 3,
  "primarySpecialtyId": 69,
  "startDate": "2023-06-01"
}

###

### Obtener profesional por ID
GET {{base}}/2
Authorization: {{token}}

###

### Obtener profesional por tercero
GET {{base}}/third/12
Authorization: {{token}}

###

### Listar profesionales (paginado)
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "size": 10,
  "search": ""
}

###

### Listar profesionales con búsqueda por nombre o registro
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "size": 10,
  "search": "RM-12345"
}

###

### Actualizar profesional
PUT {{base}}/1
Content-Type: application/json
Authorization: {{token}}

{
  "medicalRegistrationNumber": "RM-12345",
  "primarySpecialtyId": 1,
  "startDate": "2024-01-15",
  "retirementDate": null,
  "observations": "Médico general. Especialización en cardiología en curso"
}

###

### Registrar retiro de profesional
PUT {{base}}/1
Content-Type: application/json
Authorization: {{token}}

{
  "medicalRegistrationNumber": "RM-12345",
  "primarySpecialtyId": 1,
  "startDate": "2024-01-15",
  "retirementDate": "2025-12-31",
  "observations": "Retiro voluntario"
}

###

### Toggle activo/inactivo
PATCH {{base}}/1/toggle-active
Authorization: {{token}}
