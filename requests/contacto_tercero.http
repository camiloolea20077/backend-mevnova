@port = 9001
@token = Bearer eyJhbGciOiJIUzUxMiJ9..cCkUvdm8f98TNUdnNH-i8q5s32eGyZD79qBuucPIAN2ccSKxs6PE0rPOzpiDHzZPWnmM4Pu3DbQZbOdHtbboxg
@base = http://localhost:{{port}}/api/third-contacts

### Crear contacto (teléfono principal)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "thirdPartyId": 8,
  "contactTypeId": 9,
  "value": "3001234567",
  "isPrincipal": true,
  "acceptsNotifications": true
}

###

### Crear contacto (email)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "thirdPartyId": 8,
  "contactTypeId": 11,
  "value": "paciente@correo.com",
  "isPrincipal": true,
  "acceptsNotifications": true
}

###

### Obtener contacto por ID
GET {{base}}/3
Authorization: {{token}}

###

### Listar contactos de un tercero
GET {{base}}/third/1
Authorization: {{token}}

###

### Actualizar contacto
PUT {{base}}/1
Content-Type: application/json
Authorization: {{token}}

{
  "contactTypeId": 1,
  "value": "3109876543",
  "isPrincipal": true,
  "acceptsNotifications": false
}

###

### Toggle activo/inactivo
PATCH {{base}}/1/toggle-active
Authorization: {{token}}
