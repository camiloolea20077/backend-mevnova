# ─────────────────────────────────────────────────────────────────────────────
# HU-FASE1-059 — Cuenta por cobrar (creada automáticamente al aprobar factura)
# ─────────────────────────────────────────────────────────────────────────────

@baseCxC = http://localhost:{{port}}/api/billing/cuentas-por-cobrar

### Consultar CxC por ID
GET {{baseCxC}}/7
Authorization: {{token}}

###

### Consultar CxC de una factura
GET {{baseCxC}}/factura/3
Authorization: {{token}}

###

### Listar cuentas por cobrar (paginado)
POST {{baseCxC}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": null,
  "order_by": "c.fecha_causacion",
  "order": "DESC"
}

###

### Registrar abono manual sobre una CxC
POST {{baseCxC}}/7/abono
Content-Type: application/json
Authorization: {{token}}

{
  "valor": 20000.00,
  "referencia": "TRANSFERENCIA-2026-0001",
  "observaciones": "Abono parcial pagador EPS"
}

###

# ─────────────────────────────────────────────────────────────────────────────
# HU-FASE1-057 — Generación de RIPS
# ─────────────────────────────────────────────────────────────────────────────

@baseRips = http://localhost:{{port}}/api/billing/rips

### Generar RIPS desde una factura APROBADA
# Ajustar facturaId al id real de una factura en estado APROBADA
POST {{baseRips}}/generate/4
Content-Type: application/json
Authorization: {{token}}

{
  "observations": "RIPS generado para radicación EPS Sura"
}

###

### Consultar RIPS por ID
GET {{baseRips}}/7
Authorization: {{token}}

###

### Consultar RIPS de una factura
GET {{baseRips}}/factura/4
Authorization: {{token}}

###

### Consultar líneas de un RIPS (registros AC pipe-delimited)
GET {{baseRips}}/1/lines
Authorization: {{token}}

###

# ─────────────────────────────────────────────────────────────────────────────
# HU-FASE1-058 — Radicación ante pagador
# ─────────────────────────────────────────────────────────────────────────────

@baseRad = http://localhost:{{port}}/api/billing/radicaciones

### Crear radicación (radicar factura ante el pagador)
# Ajustar facturaId al id real de una factura APROBADA en tu BD
POST {{baseRad}}
Content-Type: application/json
Authorization: {{token}}

{
  "facturaId": 4,
  "numeroRadicado": "RAD-2026-002",
  "fechaRadicacion": "2026-04-28",
  "fechaLimiteRespuesta": "2026-05-28",
  "soporteUrl": null,
  "observaciones": "Radicación inicial ante EPS Sura"
}

###

### Consultar radicación por ID
GET {{baseRad}}/5
Authorization: {{token}}

###

### Listar radicaciones (paginado)
POST {{baseRad}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": null,
  "order_by": "r.fecha_radicacion",
  "order": "DESC"
}

###

### Registrar respuesta del pagador (APROBADA)
PATCH {{baseRad}}/1/respuesta
Content-Type: application/json
Authorization: {{token}}

{
  "estadoCodigo": "APROBADA",
  "fechaRespuesta": "2026-05-10",
  "observaciones": "Aprobada sin glosas"
}

###

### Registrar respuesta del pagador (RECHAZADA)
PATCH {{baseRad}}/1/respuesta
Content-Type: application/json
Authorization: {{token}}

{
  "estadoCodigo": "RECHAZADA",
  "fechaRespuesta": "2026-05-10",
  "observaciones": "Rechazada por falta de soportes clínicos"
}

###

### Registrar respuesta del pagador (DEVUELTA con glosa)
PATCH {{baseRad}}/5/respuesta
Content-Type: application/json
Authorization: {{token}}

{
  "estadoCodigo": "DEVUELTA",
  "fechaRespuesta": "2026-05-10",
  "observaciones": "Devuelta: diagnóstico no concuerda con procedimiento"
}

###

### Anular radicación (soft-delete)
DELETE {{baseRad}}/1
Authorization: {{token}}

