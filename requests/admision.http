@base = http://localhost:{{port}}/api/admissions

### HU-020 — Registrar admisión de urgencias
# tipo_admision_id=1 (URGENCIAS), origen_atencion_id=1 (Enfermedad General),
# pagador_id=1, paciente_id=1
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "patientId": 5,
  "admissionTypeId": 13,
  "careOriginId": 16,
  "payerId": 3,
  "contractId": null,
  "companionId": null,
  "entryReason": "Paciente con dolor abdominal agudo en FID de 6 horas de evolución",
  "observations": null
}

###

### HU-020 — Registrar admisión de consulta externa
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "patientId": 5,
  "admissionTypeId": 14,
  "careOriginId": 24,
  "payerId": 3,
  "contractId": 2,
  "companionId": null,
  "entryReason": "Control mensual hipertensión arterial",
  "observations": null
}

###

### HU-022 — Consultar admisión por ID
GET {{base}}/3
Authorization: {{token}}

###

### HU-022 — Listar admisiones activas de la sede (paginado)
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "a.fecha_admision",
  "order": "DESC"
}

###

### HU-022 — Buscar admisión por nombre o número de documento
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "García",
  "order_by": "a.fecha_admision",
  "order": "DESC"
}

###

### HU-023 — Cambiar estado de admisión a EN_ATENCION
PATCH {{base}}/3/status
Content-Type: application/json
Authorization: {{token}}

{
  "newStatusCode": "EN_ATENCION",
  "observations": "Paciente pasa a atención médica"
}

###

### HU-023 — Cancelar admisión
PATCH {{base}}/3/status
Content-Type: application/json
Authorization: {{token}}

{
  "newStatusCode": "CANCELADO",
  "observations": "Paciente se retira voluntariamente"
}

###

### HU-024 — Registrar egreso administrativo
# Solo permitido si todas las atenciones están cerradas
PATCH {{base}}/6/egreso
Content-Type: application/json
Authorization: {{token}}

{
  "dischargeType": "ALTA_VOLUNTARIA",
  "observations": "Paciente solicita alta voluntaria, se educa sobre riesgos"
}

###
