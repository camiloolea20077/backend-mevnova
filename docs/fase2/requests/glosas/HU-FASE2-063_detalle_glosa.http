@port = 9001
@token = Bearer eyJhbGciOiJIUzUxMiJ9..wbNcJmazn5sNz-bYTeVgm8W8YO9MBFvSwdPt-5cXaTj4YvAdbXtShaoofido_g6m3bSo2Caiaz3Iu9u3y5b9dA

@base = http://localhost:{{port}}/api/billing/glosas
@glosaId = 1
@detalleGlosaId = 1
@detalleFacturaId = 4
@motivoGlosaId = 1

### HU-FASE2-063 — Agregar ítem glosado (flujo exitoso)
POST {{base}}/items
Content-Type: application/json
Authorization: {{token}}

{
  "glossId": {{glosaId}},
  "invoiceItemId": {{detalleFacturaId}},
  "glossReasonId": {{motivoGlosaId}},
  "glossedValue": 50000.00,
  "payerObservation": "Soporte clínico incompleto."
}

###

### HU-FASE2-063 — Consultar ítem glosado por ID
GET {{base}}/items/{{detalleGlosaId}}
Authorization: {{token}}

###

### HU-FASE2-063 — Listar ítems de una glosa
GET {{base}}/{{glosaId}}/items
Authorization: {{token}}

###

### HU-FASE2-063 — Cuadre (suma vs valor total de la glosa)
GET {{base}}/{{glosaId}}/items/reconciliation
Authorization: {{token}}

###

### HU-FASE2-063 — Actualizar ítem (motivo + valor)
PUT {{base}}/items/{{detalleGlosaId}}
Content-Type: application/json
Authorization: {{token}}

{
  "glossReasonId": {{motivoGlosaId}},
  "glossedValue": 75000.00,
  "payerObservation": "Ajuste tras mesa técnica."
}

###

### HU-FASE2-063 — Eliminación lógica
DELETE {{base}}/items/{{detalleGlosaId}}
Authorization: {{token}}

###

### HU-FASE2-063 — Validación negativa: campos obligatorios vacíos
POST {{base}}/items
Content-Type: application/json
Authorization: {{token}}

{
  "glossId": null,
  "invoiceItemId": null,
  "glossReasonId": null,
  "glossedValue": 0
}

###

### HU-FASE2-063 — Validación negativa: glosa inexistente
POST {{base}}/items
Content-Type: application/json
Authorization: {{token}}

{
  "glossId": 999999,
  "invoiceItemId": {{detalleFacturaId}},
  "glossReasonId": {{motivoGlosaId}},
  "glossedValue": 1000.00
}

###

### HU-FASE2-063 — Validación negativa: detalle de factura no pertenece a la glosa
POST {{base}}/items
Content-Type: application/json
Authorization: {{token}}

{
  "glossId": {{glosaId}},
  "invoiceItemId": 999999,
  "glossReasonId": {{motivoGlosaId}},
  "glossedValue": 1000.00
}

###

### HU-FASE2-063 — Validación negativa: motivo inexistente o inactivo
POST {{base}}/items
Content-Type: application/json
Authorization: {{token}}

{
  "glossId": {{glosaId}},
  "invoiceItemId": {{detalleFacturaId}},
  "glossReasonId": 999999,
  "glossedValue": 1000.00
}

###

### HU-FASE2-063 — Validación negativa: valor glosado supera total del ítem
POST {{base}}/items
Content-Type: application/json
Authorization: {{token}}

{
  "glossId": {{glosaId}},
  "invoiceItemId": {{detalleFacturaId}},
  "glossReasonId": {{motivoGlosaId}},
  "glossedValue": 999999999.00
}

###

### HU-FASE2-063 — Validación negativa: glosa NO ABIERTA (debe rechazar)
PUT {{base}}/items/{{detalleGlosaId}}
Content-Type: application/json
Authorization: {{token}}

{
  "glossReasonId": {{motivoGlosaId}},
  "glossedValue": 50000.00
}

###

### HU-FASE2-063 — Cross-tenant: ID de otra empresa (404)
GET {{base}}/items/999999
Authorization: {{token}}

