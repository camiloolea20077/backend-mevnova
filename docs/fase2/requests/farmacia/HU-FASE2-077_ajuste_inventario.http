@tokenAprobador = Bearer eyJhbGciOiJIUzUxMiJ9..ybGHbjJ9dGpr6WmuidzUJ3lbASsmdWx_4UXhDezD-6kJ666VKb8UHeqOPtoGAsHCRmZ5nLnleb6Q9u84QTa1mg

@base = http://localhost:{{port}}/api/inventory-adjustments

@bodegaId = 1
@bodegaInexistenteId = 99999
@loteId = 1
@otroLoteId = 2
@ajusteId = 2
@ajusteInexistenteId = 99999

### HU-FASE2-077 — Crear ajuste BORRADOR (inventario físico)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "warehouseId": {{bodegaId}},
  "adjustmentType": "FISICO",
  "adjustmentDate": "2026-05-04",
  "reason": "Conteo físico mensual de bodega central. Diferencias detectadas en dos lotes.",
  "items": [
    {
      "batchId": {{loteId}},
      "systemQuantity": 100.000,
      "realQuantity": 95.000,
      "unitValue": 1500.00,
      "observations": "5 unidades faltantes detectadas en conteo"
    }
  ]
}

###

### HU-FASE2-077 — Crear ajuste BORRADOR (deterioro)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "warehouseId": {{bodegaId}},
  "adjustmentType": "DETERIORO",
  "adjustmentDate": "2026-05-04",
  "reason": "Empaque dañado durante manipulación",
  "items": [
    {
      "batchId": {{loteId}},
      "systemQuantity": 95.000,
      "realQuantity": 90.000,
      "unitValue": 1500.00,
      "observations": "5 unidades con empaque roto"
    }
  ]
}

###

### HU-FASE2-077 — Consultar ajuste por ID
GET {{base}}/{{ajusteId}}
Authorization: {{token}}

###

### HU-FASE2-077 — Listar ajustes (paginado)
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "a.fecha_ajuste",
  "order": "DESC"
}

###

### HU-FASE2-077 — Buscar ajustes por número o tipo
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "FISICO",
  "order_by": "a.created_at",
  "order": "DESC"
}

###

### HU-FASE2-077 — Aprobar ajuste (debe ejecutarlo un usuario distinto al creador)
PATCH {{base}}/{{ajusteId}}/approve
Authorization: {{tokenAprobador}}

###

### HU-FASE2-077 — Aplicar ajuste (genera movimiento_inventario y actualiza stock_lote)
PATCH {{base}}/{{ajusteId}}/apply
Authorization: {{tokenAprobador}}

###

### HU-FASE2-077 — Anular ajuste con justificación
PATCH {{base}}/{{ajusteId}}/cancel
Content-Type: application/json
Authorization: {{token}}

{
  "reason": "Diferencias atribuidas a error de captura, se anula ajuste"
}

###

### HU-FASE2-077 — Validación: campo obligatorio (warehouseId faltante)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "adjustmentType": "FISICO",
  "adjustmentDate": "2026-05-04",
  "reason": "Faltó la bodega",
  "items": [
    {
      "batchId": {{loteId}},
      "systemQuantity": 10.000,
      "realQuantity": 9.000,
      "unitValue": 1000.00
    }
  ]
}

###

### HU-FASE2-077 — Validación: tipo de ajuste inválido
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "warehouseId": {{bodegaId}},
  "adjustmentType": "INVENTADO",
  "adjustmentDate": "2026-05-04",
  "reason": "Tipo no permitido por CHECK",
  "items": [
    {
      "batchId": {{loteId}},
      "systemQuantity": 10.000,
      "realQuantity": 9.000,
      "unitValue": 1000.00
    }
  ]
}

###

### HU-FASE2-077 — Validación: lista de ítems vacía
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "warehouseId": {{bodegaId}},
  "adjustmentType": "FISICO",
  "adjustmentDate": "2026-05-04",
  "reason": "Sin ítems",
  "items": []
}

###

### HU-FASE2-077 — Validación: bodega inexistente o de otra empresa (404)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "warehouseId": {{bodegaInexistenteId}},
  "adjustmentType": "FISICO",
  "adjustmentDate": "2026-05-04",
  "reason": "Bodega que no existe",
  "items": [
    {
      "batchId": {{loteId}},
      "systemQuantity": 10.000,
      "realQuantity": 9.000,
      "unitValue": 1000.00
    }
  ]
}

###

### HU-FASE2-077 — Validación: lote duplicado dentro del mismo ajuste
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "warehouseId": {{bodegaId}},
  "adjustmentType": "FISICO",
  "adjustmentDate": "2026-05-04",
  "reason": "Mismo lote dos veces",
  "items": [
    {
      "batchId": {{loteId}},
      "systemQuantity": 10.000,
      "realQuantity": 9.000,
      "unitValue": 1000.00
    },
    {
      "batchId": {{loteId}},
      "systemQuantity": 5.000,
      "realQuantity": 4.000,
      "unitValue": 1000.00
    }
  ]
}

###

### HU-FASE2-077 — Validación: ID inexistente al consultar (404)
GET {{base}}/{{ajusteInexistenteId}}
Authorization: {{token}}

###

### HU-FASE2-077 — Validación: aprobador igual al creador (403)
PATCH {{base}}/{{ajusteId}}/approve
Authorization: {{token}}

###

### HU-FASE2-077 — Validación: aplicar ajuste no aprobado (409)
PATCH {{base}}/{{ajusteId}}/apply
Authorization: {{tokenAprobador}}

###

### HU-FASE2-077 — Validación: anular ajuste APLICADO (409)
PATCH {{base}}/{{ajusteId}}/cancel
Content-Type: application/json
Authorization: {{token}}

{
  "reason": "Intento de anular un ajuste ya aplicado"
}

