@port = 9001
@token = Bearer eyJhbGciOiJIUzUxMiJ9..wbNcJmazn5sNz-bYTeVgm8W8YO9MBFvSwdPt-5cXaTj4YvAdbXtShaoofido_g6m3bSo2Caiaz3Iu9u3y5b9dA

@base = http://localhost:{{port}}/api/batches

@loteId = 1
@servicioId = 4
@proveedorId = 1

### HU-FASE2-070 — Consultar lote por ID (incluye stock total y días al vencimiento)
GET {{base}}/{{loteId}}
Authorization: {{token}}

###

### HU-FASE2-070 — Listar lotes activos (orden por vencimiento ASC)
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "id",
  "order": "ASC"
}

###

### HU-FASE2-070 — Buscar lote por número, INVIMA o servicio
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "LOTE-A",
  "order_by": "l.fecha_vencimiento",
  "order": "ASC"
}

###

### HU-FASE2-070 — Filtro: lotes que vencen en los próximos 30 días
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "l.fecha_vencimiento",
  "order": "ASC",
  "params": {
    "expiringInDays": 30
  }
}

###

### HU-FASE2-070 — Filtro: lotes que vencen en los próximos 60 días
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "l.fecha_vencimiento",
  "order": "ASC",
  "params": {
    "expiringInDays": 60
  }
}

###

### HU-FASE2-070 — Filtro: lotes que vencen en los próximos 90 días
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "l.fecha_vencimiento",
  "order": "ASC",
  "params": {
    "expiringInDays": 90
  }
}

###

### HU-FASE2-070 — Filtro: solo lotes vencidos
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "l.fecha_vencimiento",
  "order": "DESC",
  "params": {
    "expired": true
  }
}

###

### HU-FASE2-070 — Filtro: por servicio (medicamento/insumo)
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "l.fecha_vencimiento",
  "order": "ASC",
  "params": {
    "healthServiceId": {{servicioId}}
  }
}

###

### HU-FASE2-070 — Filtro: por proveedor + solo con stock
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "l.fecha_vencimiento",
  "order": "ASC",
  "params": {
    "supplierId": {{proveedorId}},
    "onlyWithStock": true
  }
}

###

### HU-FASE2-070 — Actualizar registro INVIMA y observaciones
PUT {{base}}/{{loteId}}
Content-Type: application/json
Authorization: {{token}}

{
  "invimaRegister": "INV-2026-RENOVADO",
  "observations": "Registro INVIMA actualizado tras renovación 2026"
}

###

### HU-FASE2-070 — Actualizar limpiando observaciones
PUT {{base}}/{{loteId}}
Content-Type: application/json
Authorization: {{token}}

{
  "invimaRegister": "INV-12345",
  "observations": null
}

###

### HU-FASE2-070 — Activar/Inactivar lote (toggle)
PATCH {{base}}/{{loteId}}/toggle-active
Authorization: {{token}}

###

### HU-FASE2-070 — Validación: registro INVIMA demasiado largo
PUT {{base}}/{{loteId}}
Content-Type: application/json
Authorization: {{token}}

{
  "invimaRegister": "INV-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
}

###

### HU-FASE2-070 — Validación: consultar lote inexistente (404)
GET {{base}}/999999
Authorization: {{token}}

###

### HU-FASE2-070 — Validación: actualizar lote inexistente (404)
PUT {{base}}/999999
Content-Type: application/json
Authorization: {{token}}

{
  "invimaRegister": "INV-XX"
}

###

### HU-FASE2-070 — Validación: inactivar lote con stock disponible (400)
PATCH {{base}}/{{loteId}}/toggle-active
Authorization: {{token}}

