@port = 9001
@token = Bearer eyJhbGciOiJIUzUxMiJ9..wbNcJmazn5sNz-bYTeVgm8W8YO9MBFvSwdPt-5cXaTj4YvAdbXtShaoofido_g6m3bSo2Caiaz3Iu9u3y5b9dA

@base = http://localhost:{{port}}/api/stock

@stockId = 1
@bodegaId = 1
@servicioId = 4
@loteId = 1

### HU-FASE2-071 — Consultar fila de stock por ID
GET {{base}}/{{stockId}}
Authorization: {{token}}

###

### HU-FASE2-071 — Listar stock (orden FEFO por vencimiento ASC)
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "l.fecha_vencimiento",
  "order": "ASC"
}

###

### HU-FASE2-071 — Buscar stock por medicamento, lote o bodega
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "Acetaminofén",
  "order_by": "id",
  "order": "ASC"
}

###

### HU-FASE2-071 — Filtro: por bodega
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "l.fecha_vencimiento",
  "order": "ASC",
  "params": {
    "warehouseId": {{bodegaId}}
  }
}

###

### HU-FASE2-071 — Filtro: por medicamento
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "l.fecha_vencimiento",
  "order": "ASC",
  "params": {
    "healthServiceId": {{servicioId}}
  }
}

###

### HU-FASE2-071 — Filtro: por lote específico
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "l.fecha_vencimiento",
  "order": "ASC",
  "params": {
    "batchId": {{loteId}}
  }
}

###

### HU-FASE2-071 — Filtro: vencimiento próximo en 30 días
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "l.fecha_vencimiento",
  "order": "ASC",
  "params": {
    "expiringInDays": 30
  }
}

###

### HU-FASE2-071 — Filtro: vencimiento próximo en 60 días
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "l.fecha_vencimiento",
  "order": "ASC",
  "params": {
    "expiringInDays": 60
  }
