@port = 9001
@token = Bearer eyJhbGciOiJIUzUxMiJ9..jxtKrQ88wrmr-OXDtEV1SikFrkzsWT49kM0nj2-CGxoXAulW1BqJR5XM78jTHidEwXI_Uk1YZHULq0fAUg6fBA

@base = http://localhost:{{port}}/api/inventory-transfers

@bodegaOrigenId = 1
@bodegaDestinoId = 2
@bodegaOtraSedeId = 3
@loteId = 1
@otroLoteId = 2

### HU-FASE2-076 — Traslado dentro de la misma sede (un ítem)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "sourceWarehouseId": {{bodegaOrigenId}},
  "targetWarehouseId": {{bodegaDestinoId}},
  "reason": "Reabastecimiento botiquín de piso",
  "items": [
    {
      "batchId": {{loteId}},
      "quantity": 10
    }
  ]
}

###

### HU-FASE2-076 — Traslado entre sedes (mismo empresa)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "sourceWarehouseId": {{bodegaOrigenId}},
  "targetWarehouseId": {{bodegaOtraSedeId}},
  "reason": "Apoyo a otra sede por desabastecimiento",
  "items": [
    {
      "batchId": {{loteId}},
      "quantity": 5
    }
  ]
}

###

### HU-FASE2-076 — Traslado multi-ítem
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "sourceWarehouseId": {{bodegaOrigenId}},
  "targetWarehouseId": {{bodegaDestinoId}},
  "reason": "Transferencia mensual programada",
  "items": [
    {
      "batchId": {{loteId}},
      "quantity": 3
    },
    {
      "batchId": {{otroLoteId}},
      "quantity": 7
    }
  ]
}

###

