@port = 9001
@token = Bearer eyJhbGciOiJIUzUxMiJ9..wbNcJmazn5sNz-bYTeVgm8W8YO9MBFvSwdPt-5cXaTj4YvAdbXtShaoofido_g6m3bSo2Caiaz3Iu9u3y5b9dA

@base = http://localhost:{{port}}/api/medication-requests

@solicitudId = 1
@bodegaOrigenId = 1
@bodegaDestinoId = 2
@profesionalId = 2
@servicioId = 4

### HU-FASE2-072 — Crear solicitud de medicamento (flujo principal — prioridad NORMAL)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "sourceWarehouseId": {{bodegaOrigenId}},
  "destinationWarehouseId": {{bodegaDestinoId}},
  "requestingProfessionalId": {{profesionalId}},
  "priority": "NORMAL",
  "reason": "Reabastecimiento mensual del botiquín de piso",
  "observations": "Solicitud regular de medicamentos del servicio de hospitalización",
  "items": [
    {
      "healthServiceId": {{servicioId}},
      "requestedQuantity": 20
    },
    {
      "healthServiceId": {{servicioId}},
      "requestedQuantity": 5
    }
  ]
}

###

### HU-FASE2-072 — Crear solicitud URGENTE (un solo ítem)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "sourceWarehouseId": {{bodegaOrigenId}},
  "destinationWarehouseId": {{bodegaDestinoId}},
  "priority": "URGENTE",
  "reason": "Atención de paciente en urgencias",
  "items": [
    {
      "healthServiceId": {{servicioId}},
      "requestedQuantity": 2
    }
  ]
}

###

### HU-FASE2-072 — Crear solicitud VITAL (carro de paro)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "sourceWarehouseId": {{bodegaOrigenId}},
  "destinationWarehouseId": {{bodegaDestinoId}},
  "priority": "VITAL",
  "reason": "Reposición carro de paro tras código azul",
  "items": [
    {
      "healthServiceId": {{servicioId}},
      "requestedQuantity": 1
    }
  ]
}

###

### HU-FASE2-072 — Consultar solicitud por ID (incluye items)
GET {{base}}/{{solicitudId}}
Authorization: {{token}}

###

### HU-FASE2-072 — Listar solicitudes (orden por defecto: VITAL → URGENTE → NORMAL)
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": ""
}

###

### HU-FASE2-072 — Buscar solicitud por número o estado
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "PENDIENTE",
  "order_by": "s.fecha_solicitud",
  "order": "DESC"
}

###

### HU-FASE2-072 — Listar por número de solicitud
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "SOL-",
  "order_by": "s.fecha_solicitud",
  "order": "DESC"
}

###

### HU-FASE2-072 — Anular solicitud pendiente (con justificación)
PATCH {{base}}/{{solicitudId}}/cancel
Content-Type: application/json
Authorization: {{token}}

{
  "reason": "El servicio ya no requiere los medicamentos solicitados"
}

###

### HU-FASE2-072 — Validación: crear sin items
