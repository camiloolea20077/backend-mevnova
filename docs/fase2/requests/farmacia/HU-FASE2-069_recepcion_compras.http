@port = 9001
@token = Bearer eyJhbGciOiJIUzUxMiJ9..wbNcJmazn5sNz-bYTeVgm8W8YO9MBFvSwdPt-5cXaTj4YvAdbXtShaoofido_g6m3bSo2Caiaz3Iu9u3y5b9dA

@base = http://localhost:{{port}}/api/purchases

@compraId = 1
@bodegaId = 1
@proveedorId = 1
@servicioId = 4

### HU-FASE2-069 — Crear compra en BORRADOR (flujo principal)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "warehouseId": {{bodegaId}},
  "supplierId": {{proveedorId}},
  "supplierInvoiceNumber": "FACT-PROV-001",
  "purchaseDate": "2026-05-01",
  "receptionDate": "2026-05-03",
  "supportUrl": "https://files.mednova.com/soportes/compra-001.pdf",
  "observations": "Recepción mensual de medicamentos",
  "items": [
    {
      "healthServiceId": {{servicioId}},
      "batchNumber": "LOTE-A-001",
      "manufacturingDate": "2026-01-15",
      "expirationDate": "2027-12-31",
      "invimaRegister": "INV-12345",
      "quantity": 100,
      "unitValue": 1500.00,
      "vatPercentage": 19.00,
      "discountPercentage": 5.00,
      "observations": "Caja de 100 unidades"
    }
  ]
}

###

### HU-FASE2-069 — Consultar compra por ID (incluye detalles)
GET {{base}}/{{compraId}}
Authorization: {{token}}

###

### HU-FASE2-069 — Listar compras
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "c.fecha_compra",
  "order": "DESC"
}

###

### HU-FASE2-069 — Buscar compra por número o factura
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "COMP-",
  "order_by": "c.fecha_compra",
  "order": "DESC"
}

###

### HU-FASE2-069 — Confirmar recepción (BORRADOR → RECIBIDA)
PATCH {{base}}/{{compraId}}/receive
Authorization: {{token}}

###

### HU-FASE2-069 — Anular compra (con justificación)
PATCH {{base}}/{{compraId}}/cancel
Content-Type: application/json
Authorization: {{token}}

{
  "reason": "Factura duplicada por error del proveedor"
}

###

### HU-FASE2-069 — Validación: crear sin items
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "warehouseId": {{bodegaId}},
  "supplierId": {{proveedorId}},
  "purchaseDate": "2026-05-01",
  "items": []
}

###

### HU-FASE2-069 — Validación: crear sin bodega (campo obligatorio)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "supplierId": {{proveedorId}},
  "purchaseDate": "2026-05-01",
  "items": [
    {
      "healthServiceId": {{servicioId}},
      "batchNumber": "LOTE-X",
      "expirationDate": "2027-01-01",
      "quantity": 10,
      "unitValue": 1000
    }
  ]
}

