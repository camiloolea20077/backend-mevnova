@port = 9001
@token = Bearer eyJhbGciOiJIUzUxMiJ9..jxtKrQ88wrmr-OXDtEV1SikFrkzsWT49kM0nj2-CGxoXAulW1BqJR5XM78jTHidEwXI_Uk1YZHULq0fAUg6fBA

@base = http://localhost:{{port}}/api/dispensations

@dispensacionId = 2
@detalleDispensacionId = 1
@detalleDispensacionId2 = 2
@bodegaDestinoId = 1

### HU-FASE2-075 — Registrar devolución (lote no vencido => DEVOLUCION_PACIENTE + stock)
POST {{base}}/{{dispensacionId}}/returns
Content-Type: application/json
Authorization: {{token}}

{
  "targetWarehouseId": {{bodegaDestinoId}},
  "items": [
    {
      "dispensationDetailId": {{detalleDispensacionId}},
      "quantity": 2,
      "reason": "Paciente egresado, medicamento no aplicado"
    }
  ]
}

###

### HU-FASE2-075 — Registrar devolución parcial multi-ítem
POST {{base}}/{{dispensacionId}}/returns
Content-Type: application/json
Authorization: {{token}}

{
  "targetWarehouseId": {{bodegaDestinoId}},
  "items": [
    {
      "dispensationDetailId": {{detalleDispensacionId}},
      "quantity": 1,
      "reason": "Suspensión médica"
    },
    {
      "dispensationDetailId": {{detalleDispensacionId2}},
      "quantity": 1,
      "reason": "Sobrante de turno"
    }
  ]
}

###

### HU-FASE2-075 — Devolución de lote vencido (genera BAJA_VENCIMIENTO sin stock)
