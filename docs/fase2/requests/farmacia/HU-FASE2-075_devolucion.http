Authorization: {{token}}

{
  "targetWarehouseId": {{bodegaDestinoId}},
  "items": [
    {
      "dispensationDetailId": {{detalleDispensacionId}},
      "quantity": 1,
      "reason": "Prueba"
    }
  ]
}

###

