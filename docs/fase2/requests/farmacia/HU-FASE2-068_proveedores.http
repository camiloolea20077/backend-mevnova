@base = http://localhost:{{port}}/api/suppliers

@proveedorId = 1
@terceroId = 8

### HU-FASE2-068 — Crear proveedor (flujo principal)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "thirdPartyId": 14,
  "code": "PROV-001",
  "accountingAccount": "220505",
  "paymentTermDays": 30,
  "earlyPaymentDiscount": 2.50,
  "requiresPurchaseOrder": true,
  "observations": "Proveedor principal de medicamentos"
}

###

### HU-FASE2-068 — Crear proveedor con valores mínimos
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "thirdPartyId": 11,
  "code": "PROV-002"
}

###

### HU-FASE2-068 — Consultar proveedor por ID
GET {{base}}/{{proveedorId}}
Authorization: {{token}}

###

### HU-FASE2-068 — Listar proveedores activos
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "p.codigo",
  "order": "ASC"
}

###

### HU-FASE2-068 — Buscar proveedor por código o nombre del tercero
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "PROV",
  "order_by": "p.codigo",
  "order": "ASC"
}

###

### HU-FASE2-068 — Actualizar proveedor
PUT {{base}}/{{proveedorId}}
Content-Type: application/json
Authorization: {{token}}

{
  "accountingAccount": "220510",
  "paymentTermDays": 45,
  "earlyPaymentDiscount": 3.00,
  "requiresPurchaseOrder": false,
  "observations": "Plazo de pago renegociado"
}

###

### HU-FASE2-068 — Activar/Inactivar proveedor (toggle)
PATCH {{base}}/{{proveedorId}}/toggle-active
Authorization: {{token}}

###

### HU-FASE2-068 — Validación: crear sin código (campo obligatorio)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "thirdPartyId": {{terceroId}}
}

###

### HU-FASE2-068 — Validación: crear sin tercero (campo obligatorio)
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "code": "PROV-SIN-TERCERO"
}

###

### HU-FASE2-068 — Validación: descuento por pronto pago fuera de rango
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "thirdPartyId": 14,
  "code": "PROV-DESC-INVALIDO",
  "earlyPaymentDiscount": 150.00
}

###

### HU-FASE2-068 — Validación: plazo de pago negativo
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "thirdPartyId": {{terceroId}},
  "code": "PROV-PLAZO-INVALIDO",
  "paymentTermDays": -10
}

###

### HU-FASE2-068 — Validación: tercero inexistente o no es PROVEEDOR
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "thirdPartyId": 999999,
  "code": "PROV-TERCERO-INVALIDO"
}

###

### HU-FASE2-068 — Validación: código duplicado en la empresa
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "thirdPartyId": 12,
  "code": "PROV-001",
  "observations": "Debe fallar porque el código ya existe en la empresa"
}

###

### HU-FASE2-068 — Validación: tercero ya registrado como proveedor
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "thirdPartyId": {{terceroId}},
  "code": "PROV-DUPLICADO-TERCERO",
  "observations": "Debe fallar porque el tercero ya es proveedor"
}

###

### HU-FASE2-068 — Validación: consultar proveedor inexistente
GET {{base}}/999999
Authorization: {{token}}

###

### HU-FASE2-068 — Validación: actualizar proveedor inexistente
PUT {{base}}/999999
Content-Type: application/json
Authorization: {{token}}

{
  "paymentTermDays": 60
}

