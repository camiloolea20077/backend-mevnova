@port = 9001
@token = Bearer eyJhbGciOiJIUzUxMiJ9..x03GWJijsBLCDZL53kJPd-gU6xV_UuMXwULM_SjqNTlK8bDDK_eE2iRmBynarmh3P7jAHn1EgOaHpeo73-It_w


@base = http://localhost:{{port}}/api/kardex

@loteId = 1
@otroLoteId = 2
@servicioSaludId = 1
@bodegaId = 1
@sedeId = 1
@loteInexistenteId = 99999

### HU-FASE2-078 — Kardex por lote (movimientos cronológicos con saldo acumulado)
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 20,
  "search": "",
  "order_by": "fecha_movimiento",
  "order": "DESC",
  "params": {
    "batchId": {{loteId}}
  }
}

###

### HU-FASE2-078 — Kardex por servicio (todos los lotes del medicamento)
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 20,
  "search": "",
  "order_by": "fecha_movimiento",
  "order": "DESC",
  "params": {
    "healthServiceId": {{servicioSaludId}}
  }
}

###

### HU-FASE2-078 — Kardex con filtros de bodega y rango de fechas
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 50,
  "search": "",
  "order_by": "fecha_movimiento",
  "order": "ASC",
  "params": {
    "batchId": {{loteId}},
    "warehouseId": {{bodegaId}},
    "fromDate": "2026-01-01",
    "toDate": "2026-12-31"
  }
}

###

### HU-FASE2-078 — Kardex filtrado por tipo de movimiento (solo dispensaciones)
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 20,
  "search": "",
  "order_by": "fecha_movimiento",
  "order": "DESC",
  "params": {
    "batchId": {{loteId}},
    "movementType": "SALIDA_DISPENSACION"
  }
}

