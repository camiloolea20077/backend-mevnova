Content-Type: application/json
Authorization: {{token}}

{
  "sedeId": {{sedeId}},
  "code": "FARM-CENTRAL-01",
  "name": "Farmacia Central Duplicada",
  "warehouseType": "FARMACIA_CENTRAL",
  "responsibleId": {{responsableId}},
  "physicalLocation": "Primer piso - bloque principal",
