@base = http://localhost:{{port}}/api/warehouses

@bodegaId = 1
@sedeId = 1
@responsableId = 2

### HU-FASE2-067 — Crear bodega farmacia central
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "branchId": 1,
  "code": "FARM-CENTRAL-01",
  "name": "Farmacia Central",
  "warehouseType": "FARMACIA_CENTRAL",
  "responsibleId": {{responsableId}},
  "physicalLocation": "Primer piso - bloque principal",
  "main": true,
  "allowsDispensing": true,
  "allowsReceiving": true,
  "observations": "Bodega principal de farmacia"
}

###

### HU-FASE2-067 — Crear bodega botiquín de piso
POST {{base}}
Content-Type: application/json
Authorization: {{token}}

{
  "branchId": {{sedeId}},
  "code": "BOT-PISO-02",
  "name": "Botiquín Piso 2",
  "warehouseType": "BOTIQUIN_PISO",
  "responsibleId": {{responsableId}},
  "physicalLocation": "Segundo piso - hospitalización",
  "main": false,
  "allowsDispensing": true,
  "allowsReceiving": true,
  "observations": "Botiquín operativo para servicio de hospitalización"
}

###

### HU-FASE2-067 — Consultar bodega por ID
GET {{base}}/{{bodegaId}}
Authorization: {{token}}

###

### HU-FASE2-067 — Listar bodegas activas de la sede
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "b.nombre",
  "order": "ASC"
}

###

### HU-FASE2-067 — Buscar bodega por nombre o código
POST {{base}}/list
Content-Type: application/json
Authorization: {{token}}

{
  "page": 0,
  "rows": 10,
  "search": "",
  "order_by": "id",
  "order": "ASC"
}

###

### HU-FASE2-067 — Actualizar bodega
PUT {{base}}/{{bodegaId}}
Content-Type: application/json
Authorization: {{token}}

{
  "name": "Farmacia Central Actualizada",
  "warehouseType": "FARMACIA_CENTRAL",
  "responsibleId": {{responsableId}},
  "physicalLocation": "Primer piso - zona farmacia",
  "main": true,
  "allowsDispensing": true,
  "allowsReceiving": true,
  "observations": "Actualización de datos generales de la bodega"
}

###

### HU-FASE2-067 — Inactivar bodega
DELETE {{base}}/{{bodegaId}}
Authorization: {{token}}

