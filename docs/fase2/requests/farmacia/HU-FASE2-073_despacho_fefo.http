@port = 9001
@token = Bearer eyJhbGciOiJIUzUxMiJ9..wbNcJmazn5sNz-bYTeVgm8W8YO9MBFvSwdPt-5cXaTj4YvAdbXtShaoofido_g6m3bSo2Caiaz3Iu9u3y5b9dA

@base = http://localhost:{{port}}/api/medication-requests

@solicitudId = 1
@detalleId = 1
@detalleId2 = 2
@loteId = 1
@otroLoteId = 2

### HU-FASE2-073 — Obtener sugerencia FEFO por ítem pendiente
GET {{base}}/{{solicitudId}}/dispatch-suggestion
Authorization: {{token}}

###

### HU-FASE2-073 — Despachar usando sugerencia FEFO (sin batchId, lo elige el sistema)
PATCH {{base}}/{{solicitudId}}/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": [
    {
      "detailId": {{detalleId}},
      "quantityToDispatch": 20
    }
  ]
}

###

### HU-FASE2-073 — Despachar especificando lote (coincide con FEFO)
PATCH {{base}}/{{solicitudId}}/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": [
    {
      "detailId": {{detalleId}},
      "batchId": {{loteId}},
      "quantityToDispatch": 20
    }
  ]
}

###

### HU-FASE2-073 — Despachar varios ítems en una sola operación
PATCH {{base}}/{{solicitudId}}/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": [
    {
      "detailId": {{detalleId}},
      "quantityToDispatch": 10
    },
    {
      "detailId": {{detalleId2}},
      "quantityToDispatch": 5
    }
  ]
}

###

### HU-FASE2-073 — Override FEFO con justificación (lote distinto al sugerido)
PATCH {{base}}/{{solicitudId}}/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": [
    {
      "detailId": {{detalleId}},
      "batchId": {{otroLoteId}},
      "quantityToDispatch": 10,
      "overrideReason": "Lote sugerido reservado para urgencias del día"
    }
  ]
}

###

### HU-FASE2-073 — Despacho parcial (cantidad mayor que disponible se ajusta a stock)
PATCH {{base}}/{{solicitudId}}/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": [
    {
      "detailId": {{detalleId}},
      "quantityToDispatch": 999
    }
  ]
}

###

### HU-FASE2-073 — Consultar solicitud después del despacho (estado y cantidad_despachada)
GET {{base}}/{{solicitudId}}
Authorization: {{token}}

###

### HU-FASE2-073 — Validación: despachar sin items
PATCH {{base}}/{{solicitudId}}/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": []
}

###

### HU-FASE2-073 — Validación: cantidad cero o negativa
PATCH {{base}}/{{solicitudId}}/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": [
    {
      "detailId": {{detalleId}},
      "quantityToDispatch": 0
    }
  ]
}

###

### HU-FASE2-073 — Validación: detalleId inexistente o de otra solicitud (404)
PATCH {{base}}/{{solicitudId}}/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": [
    {
      "detailId": 999999,
      "quantityToDispatch": 10
    }
  ]
}

###

### HU-FASE2-073 — Validación: lote sin stock en bodega origen (404)
PATCH {{base}}/{{solicitudId}}/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": [
    {
      "detailId": {{detalleId}},
      "batchId": 999999,
      "quantityToDispatch": 5,
      "overrideReason": "Probar lote inexistente"
    }
  ]
}

###

### HU-FASE2-073 — Validación: override sin justificación cuando difiere de FEFO (400)
PATCH {{base}}/{{solicitudId}}/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": [
    {
      "detailId": {{detalleId}},
      "batchId": {{otroLoteId}},
      "quantityToDispatch": 5
    }
  ]
}

###

### HU-FASE2-073 — Validación: cantidad mayor que pendiente del detalle (400)
PATCH {{base}}/{{solicitudId}}/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": [
    {
      "detailId": {{detalleId}},
      "quantityToDispatch": 9999999
    }
  ]
}

###

### HU-FASE2-073 — Validación: despachar solicitud no pendiente/en_proceso/parcial (409)
PATCH {{base}}/{{solicitudId}}/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": [
    {
      "detailId": {{detalleId}},
      "quantityToDispatch": 1
    }
  ]
}

###

### HU-FASE2-073 — Validación: solicitud inexistente (404)
PATCH {{base}}/999999/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": [
    {
      "detailId": 1,
      "quantityToDispatch": 1
    }
  ]
}

###

### HU-FASE2-073 — Validación: detalle ya procesado (409)
PATCH {{base}}/{{solicitudId}}/dispatch
Content-Type: application/json
Authorization: {{token}}

{
  "items": [
    {
      "detailId": {{detalleId}},
      "quantityToDispatch": 1
    }
  ]
}

###
